<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LotofacilActivity">

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="344dp"
        android:layout_height="84dp"
        android:layout_marginTop="50dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/lotofacil_logo_5" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/imgLogo"
        app:layout_constraintBottom_toBottomOf="parent">

        <EditText
            android:id="@+id/edtQtdNumeros"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Quantidade de números"
            android:inputType="number" />

        <EditText
            android:id="@+id/edtQtdJogos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Quantidade de jogos"
            android:inputType="number" />

        <Button
            android:id="@+id/btnGerar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#930089"
            android:text="Gerar Jogos" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtResultado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="20dp"
                    android:textSize="18sp"
                    android:text="Números sorteados: "
                    android:visibility="invisible"
                    android:textColor="?android:attr/textColorPrimary"
                    android:alpha="0.8"/>

                <GridLayout
                    android:id="@+id/gridResultado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="6"
                    android:paddingTop="20dp"/>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>