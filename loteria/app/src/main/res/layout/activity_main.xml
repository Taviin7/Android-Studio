<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="344dp"
        android:layout_height="84dp"
        android:layout_marginTop="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.492"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/loterias_caixa_logo_5" />

    <LinearLayout
        android:id="@+id/layoutBotoes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toBottomOf="@id/imgLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnMega"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mega-Sena"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnQuina"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quina"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnLotofacil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lotofácil"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnLotomania"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lotomania"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>